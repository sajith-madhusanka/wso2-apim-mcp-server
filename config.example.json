{
  "baseDir": "/path/to/your/distributed_deployment",
  "mysql": {
    "host": "127.0.0.1",
    "port": 3306,
    "adminUser": "root",
    "adminPassword": "your-mysql-root-password"
  },
  "databases": {
    "amDb": {
      "name": "APIM_46_AM_DB",
      "user": "apim46_am_user",
      "password": "APIM46_DB@123"
    },
    "sharedDb": {
      "name": "APIM_46_SHARED_DB",
      "user": "apim46_shared_user",
      "password": "APIM46_DB@123"
    }
  },
  "admin": {
    "username": "admin",
    "password": "admin"
  },
  "zips": {
    "tm": "/path/to/wso2am-tm-4.6.0.17.zip",
    "acp": "/path/to/wso2am-acp-4.6.0.18.zip",
    "gw": "/path/to/wso2am-universal-gw-4.6.0.zip"
  },
  "jdbcDriver": {
    "version": "8.0.29",
    "downloadUrl": "https://repo1.maven.org/maven2/mysql/mysql-connector-java/8.0.29/mysql-connector-java-8.0.29.jar"
  },
  "components": {
    "tm": {
      "label": "Traffic Manager",
      "dir": "wso2am-tm-4.6.0",
      "script": "bin/traffic-manager.sh",
      "offset": 2,
      "mgtPort": 9445,
      "logFile": "repository/logs/wso2carbon.log",
      "pidFile": "wso2carbon.pid"
    },
    "acp": {
      "label": "API Control Plane",
      "dir": "wso2am-acp-4.6.0",
      "script": "bin/api-cp.sh",
      "offset": 0,
      "mgtPort": 9443,
      "logFile": "repository/logs/wso2carbon.log",
      "pidFile": "wso2carbon.pid"
    },
    "gw": {
      "label": "Universal Gateway",
      "dir": "wso2am-universal-gw-4.6.0",
      "script": "bin/gateway.sh",
      "offset": 1,
      "mgtPort": 9444,
      "apiHttps": 8244,
      "apiHttp": 8281,
      "logFile": "repository/logs/wso2carbon.log",
      "pidFile": "wso2carbon.pid"
    }
  }
}
