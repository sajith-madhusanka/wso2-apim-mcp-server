# ─────────────────────────────────────────────────────────────────────────────
# WSO2 APIM 4.6.0 MCP Server — Environment Configuration
#
# 1. Copy this file:   cp .env.example .env
# 2. Edit .env with your values
# 3. Load before starting the agent:
#       source .env
#    or (if your shell doesn't support source):
#       set -a && . .env && set +a
# ─────────────────────────────────────────────────────────────────────────────

# ── Deployment ────────────────────────────────────────────────────────────────
# Absolute path to the directory where APIM components will be extracted.
# Must not contain spaces. Use underscores (e.g. /opt/wso2/distributed_deployment).
APIM_BASE_DIR=/path/to/your/deployment

# ── MySQL ─────────────────────────────────────────────────────────────────────
# Admin credentials used to create databases and users.
APIM_MYSQL_HOST=127.0.0.1
APIM_MYSQL_PORT=3306
APIM_MYSQL_ADMIN_USER=root
APIM_MYSQL_ADMIN_PASSWORD=your_mysql_root_password

# ── APIM Databases ────────────────────────────────────────────────────────────
# These databases and users are auto-created by the setup_databases tool.
# Default names work for most setups — change only if you need custom names.
APIM_AM_DB_NAME=APIM_46_AM_DB
APIM_AM_DB_USER=apim46_am_user
APIM_AM_DB_PASSWORD=APIM46_DB@123

APIM_SHARED_DB_NAME=APIM_46_SHARED_DB
APIM_SHARED_DB_USER=apim46_shared_user
APIM_SHARED_DB_PASSWORD=APIM46_DB@123

# ── WSO2 Admin Console ────────────────────────────────────────────────────────
# Credentials for the APIM management console (https://localhost:9443).
APIM_ADMIN_USERNAME=admin
APIM_ADMIN_PASSWORD=admin

# ── WSO2 Account (U2 Updates) ─────────────────────────────────────────────────
# Your account at https://wso2.com/user — required only for applying U2 updates.
APIM_WSO2_USERNAME=your@email.com
APIM_WSO2_PASSWORD=your_wso2_password

# ── APIM ZIP Archives ─────────────────────────────────────────────────────────
# Absolute paths to the downloaded ZIP files.
# Download from: https://wso2.com/api-manager/ → Enterprise → 4.6.0
# Note: KM uses the same ZIP as ACP — APIM_ZIP_KM is set automatically.
APIM_ZIP_TM=/path/to/wso2am-tm-4.6.0.x.zip
APIM_ZIP_ACP=/path/to/wso2am-acp-4.6.0.x.zip
APIM_ZIP_GW=/path/to/wso2am-universal-gw-4.6.0.zip

# ── MySQL JDBC Driver ─────────────────────────────────────────────────────────
# Version downloaded from Maven Central and installed into each component's lib/.
APIM_JDBC_DRIVER_VERSION=8.0.29

# ── Auto-managed (do not edit manually) ──────────────────────────────────────
# Set automatically by setup_update_tool — path to the wso2update binary.
# APIM_UPDATE_TOOL_PATH=
# Set automatically when ACP zip is provided — KM uses same archive.
# APIM_ZIP_KM=
